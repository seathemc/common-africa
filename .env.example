# Supabase Postgres (used via Prisma)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres?sslmode=require"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres?sslmode=require"

# Supabase client (optional, for future auth)
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Site
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Email (Resend). If RESEND_API_KEY is unset the verification link is logged
# to the server console — useful for local development.
RESEND_API_KEY=""
EMAIL_FROM="Common <noreply@common-africa.org>"
